# Stage 1: Build
FROM node:22-alpine AS builder
WORKDIR /app

# Copy package files
COPY package*.json ./
RUN npm ci --only=production

# Copy source code
COPY src/ ./src/

# Stage 2: Distroless runtime
FROM gcr.io/distroless/nodejs22-debian12:latest
WORKDIR /app
COPY --from=builder /app .

EXPOSE 3000
CMD ["src/index.js"]